# API Keys for image generation models
# Copy this file to .env and fill in your actual API keys

# OpenAI API Key (required for DALL-E 2)
OPENAI_API_KEY='sk-your-openai-api-key-here'

# HuggingFace Token (required for Stable Diffusion)
HUGGINGFACE_TOKEN='hf_your-huggingface-token-here'

# Replicate API Token (required for NVIDIA SANA and PixArt)
REPLICATE_API_TOKEN='r8_your-replicate-api-token-here'
